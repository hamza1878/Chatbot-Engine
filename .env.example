# Moviroo AI Chatbot — Environment Variables
# Copy this file to .env and adjust values

# App
APP_NAME=Moviroo AI Chatbot
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Database (SQLite by default, swap for PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./moviroo.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/moviroo

# Embedding model (multilingual, supports EN/FR/AR/Franco-Arabic)
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSION=768

# FAISS
FAISS_INDEX_TYPE=IndexFlatIP
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.45

# RAG confidence routing
HIGH_CONFIDENCE_THRESHOLD=0.82
LOW_CONFIDENCE_THRESHOLD=0.55

# LLM — Ollama (local)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=400
LLM_TIMEOUT=30.0

# Paths
MODELS_DIR=models_data
DATA_DIR=data
LOG_FILE=logs/app.log
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
